\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamercolorthemeavalanche}[2026/05/29 v1.0 Avalanche Workshop Theme]

\definecolor{avared}{HTML}{E84142}
\definecolor{avaredark}{HTML}{B82E2F}
\definecolor{avaaccent}{HTML}{F5A420}
\definecolor{avadark}{HTML}{0D0D0D}
\definecolor{avalight}{HTML}{F8F8F8}
\definecolor{avagray}{HTML}{EBEBEB}
\definecolor{avagraydark}{HTML}{AAAAAA}
\definecolor{avatext}{HTML}{1A1A1A}
\definecolor{avawhite}{HTML}{FFFFFF}

\setbeamercolor{background canvas}{bg=avalight}
\setbeamercolor{normal text}{fg=avatext, bg=avalight}
\setbeamercolor{alerted text}{fg=avared}
\setbeamercolor{example text}{fg=avaredark}

\setbeamercolor{title}{fg=avawhite}
\setbeamercolor{subtitle}{fg=avaaccent}
\setbeamercolor{section header}{fg=avawhite}
\setbeamercolor{author}{fg=avawhite}
\setbeamercolor{institute}{fg=avagraydark}
\setbeamercolor{date}{fg=avagraydark}

\setbeamercolor{structure}{fg=avared}
\setbeamercolor{frametitle}{fg=avatext, bg=}
\setbeamercolor{framesubtitle}{fg=avared, bg=}

\setbeamercolor{block title}{fg=avawhite, bg=avared}
\setbeamercolor{block body}{fg=avatext, bg=avagray}
\setbeamercolor{block title alerted}{fg=avawhite, bg=avaredark}
\setbeamercolor{block body alerted}{fg=avatext, bg=avagray}
\setbeamercolor{block title example}{fg=avawhite, bg=avaredark}
\setbeamercolor{block body example}{fg=avatext, bg=avagray}

\setbeamercolor{item}{fg=avared}
\setbeamercolor{itemize item}{fg=avared}
\setbeamercolor{itemize subitem}{fg=avaredark}
\setbeamercolor{itemize subsubitem}{fg=avaaccent}

\setbeamercolor{footline}{fg=avagraydark}
